# ─── Dependencies ────────────────────────────────────────────────────────────
**/node_modules/
.pnp
.pnp.*

# ─── Build outputs ───────────────────────────────────────────────────────────
**/.next/
**/dist/
**/out/
**/build/
**/*.tsbuildinfo

# ─── Environment / Secrets ───────────────────────────────────────────────────
# ALL .env files are secret — only .env.example files are safe to commit.
**/.env
**/.env.*
!**/.env.example
!**/.env.*.example

# infra/env/ — real values, VPS copy-paste, references (NEVER commit)
infra/env/*
!infra/env/*.example
infra/env/*COPY*
infra/env/*VPS*
infra/env/*.reference
infra/env/*.txt
infra/env/*.production
infra/env/*.staging
infra/env/*.devnet
infra/env/*.local
infra/env/*.md

# ─── Infra ops docs (IPs, deploy steps, passwords in notes — local only) ─────
infra/**/*.md
work.md
*.env.md

# ─── WireGuard (live config & keys on VPS only; *.example is safe template) ──
infra/wireguard/*
!infra/wireguard/*.example
**/wireguard/*.key
**/*_private.key
**/*_public.key

# ─── Ops runbooks with VPS IPs / tunnel steps (local copy only) ──────────────
docs/WIREGUARD*.md
docs/LANGKAH_STABILKAN_TUNNEL_CANTON.md
docs/SESSION_HANDOFF.md

# ─── Local-only ops scripts (contain VPS IP / tunnel setup) ──────────────────
infra/vps2-setup-tunnels.sh
infra/systemd/*
!infra/systemd/canton-tunnel.service.example
infra/deploy.sh
infra/redeploy.sh
infra/cleanup.sh

# ─── SSH / TLS / Keys ────────────────────────────────────────────────────────
**/*.pem
**/*.key
**/*.crt
**/*.p12
**/*.pfx
**/id_rsa
**/id_ed25519
**/*_tunnel
**/*_tunnel.pub

# ─── Database ────────────────────────────────────────────────────────────────
**/prisma/*.db
**/prisma/*.db-journal
**/prisma/dev.db

# ─── Logs ────────────────────────────────────────────────────────────────────
**/npm-debug.log*
**/yarn-debug.log*
**/yarn-error.log*
**/.pnpm-debug.log*
**/logs/
**/*.log

# ─── DAML build cache ────────────────────────────────────────────────────────
packages/daml/.daml/

# ─── Uploads / Media ─────────────────────────────────────────────────────────
apps/web/public/quest-media/*
!apps/web/public/quest-media/.gitkeep
apps/api/uploads/**
!apps/api/uploads/.gitkeep
!apps/api/uploads/avatars/.gitkeep

# ─── Vercel ──────────────────────────────────────────────────────────────────
.vercel

# ─── OS / Editor ─────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.idea/
*.swp
*.swo
nul
