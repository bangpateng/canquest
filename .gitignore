# ─── Dependencies ────────────────────────────────────────────────────────────
**/node_modules/
.pnp
.pnp.*

# ─── Build outputs ───────────────────────────────────────────────────────────
**/.next/
**/dist/
**/out/
**/build/
**/*.tsbuildinfo

# ─── Environment / Secrets ───────────────────────────────────────────────────
# ALL .env files are secret — only .env.example files are safe to commit.
**/.env
**/.env.*
!**/.env.example
!**/.env.*.example

# infra/env/ — production, staging, devnet env files (NEVER commit these)
infra/env/*.production
infra/env/*.staging
infra/env/*.devnet
infra/env/*.local
# Only allow the example/template files
!infra/env/*.example

# ─── SSH / TLS / Keys ────────────────────────────────────────────────────────
**/*.pem
**/*.key
**/*.crt
**/*.p12
**/*.pfx
**/id_rsa
**/id_ed25519
**/*_tunnel
**/*_tunnel.pub

# ─── Database ────────────────────────────────────────────────────────────────
**/prisma/*.db
**/prisma/*.db-journal
**/prisma/dev.db

# ─── Logs ────────────────────────────────────────────────────────────────────
**/npm-debug.log*
**/yarn-debug.log*
**/yarn-error.log*
**/.pnpm-debug.log*
**/logs/
**/*.log

# ─── Uploads / Media ─────────────────────────────────────────────────────────
apps/web/public/quest-media/*
!apps/web/public/quest-media/.gitkeep

# ─── Vercel ──────────────────────────────────────────────────────────────────
.vercel

# ─── OS / Editor ─────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.idea/
*.swp
*.swo
