# VPS 1 — TestNet validator (replace VPS1_PUBLIC_HOST with your server)
# After keys: sudo cp to /etc/wireguard/wg0.conf && wg-quick up wg0

[Interface]
Address = 10.66.66.1/24
ListenPort = 51820
PrivateKey = VPS1_PRIVATE_KEY_HERE

PostUp = sysctl -w net.ipv4.ip_forward=1
PostUp = iptables -A FORWARD -i wg0 -j ACCEPT; iptables -A FORWARD -o wg0 -j ACCEPT
PostUp = iptables -t nat -A POSTROUTING -o docker0 -j MASQUERADE
PostDown = iptables -D FORWARD -i wg0 -j ACCEPT; iptables -D FORWARD -o wg0 -j ACCEPT
PostDown = iptables -t nat -D POSTROUTING -o docker0 -j MASQUERADE

[Peer]
# VPS 2 — CanQuest API host
PublicKey = VPS2_PUBLIC_KEY_HERE
AllowedIPs = 10.66.66.2/32
