# CanQuest API — TestNet ONLY (validator VPS 162.250.190.204)
# App VPS 2 (62.171.185.56) is unchanged — only tunnel target + Canton vars differ per network.
# See docs/NETWORK_TOPOLOGY.md — do NOT use DevNet 162.250.191.46 here.
# Copy to apps/api/.env (local dev with SSH tunnel) or merge into VPS 2 production env.

NODE_ENV=development
PORT=3001
WEB_ORIGIN=http://localhost:3000

DATABASE_URL=postgresql://canquest:canquest_dev@localhost:5432/canquest_testnet
JWT_ACCESS_SECRET=change-me-to-a-long-random-string-min-32-chars
JWT_REFRESH_SECRET=change-me-different-refresh-secret-min-32-chars
INVITE_CODES=CANQUEST
AUTH_REGISTER_SKIP_OTP=true
REDIS_URL=redis://localhost:6379

# ─── SSH tunnel to 162.250.190.204 (run scripts/tunnel-testnet.ps1) ─────────
#   -L 7575:<PARTICIPANT_DOCKER_IP>:7575
#   -L 8080:<NGINX_DOCKER_IP>:80
CANTON_JSON_API_URL=http://127.0.0.1:7575
CANTON_VALIDATOR_URL=http://127.0.0.1:8080
CANTON_VALIDATOR_HOST_HEADER=wallet.localhost

# From: docker exec splice-validator-validator-1 env | grep -i secret
CANTON_SPLICE_SECRET=CHANGE_ME_FROM_TESTNET_VALIDATOR
CANTON_LEDGER_API_AUDIENCE=https://canton.network.global
CANTON_SPLICE_AUDIENCE=https://canton.network.global
CANTON_LEDGER_API_USER=ledger-api-user
CANTON_VALIDATOR_ADMIN_USER=administrator

# From: curl .../admin/users/administrator on validator (TestNet party)
CANTON_VALIDATOR_PARTY_ID=CHANGE_ME_TESTNET_PARTY
CANTON_APP_PROVIDER_PARTY_ID=CHANGE_ME_TESTNET_PARTY
CANTON_OPERATOR_PARTY_ID=CHANGE_ME_TESTNET_PARTY

# After: daml build + upload-daml-dar.cjs on TestNet participant
QUEST_LEDGER_ENABLED=false
FEATURED_APP_MARKERS_ENABLED=false
QUEST_SUBMIT_REQUIRES_WALLET=false
CANTON_DAML_PACKAGE_ID=

TRANSACTION_FEE_CC=5
CC_USD_PRICE=0

CC_INBOUND_SYNC_ENABLED=true
CC_INBOUND_SYNC_POLL_MS=30000

BALANCE_READ_FROM_DB=true
BALANCE_DB_MAX_AGE_MS=60000
BALANCE_BACKGROUND_DEBOUNCE_MS=15000
LEDGER_INDEXER_ENABLED=true
LEDGER_INDEXER_PARTY_IDS=
LEDGER_INDEXER_POLL_INTERVAL_MS=15000
