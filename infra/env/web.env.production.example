# ─── VPS 2 (same server as API) — copy to apps/web/.env ───────────────────────
# Nginx proxies /api → :3001 and /* → :3000 (see infra/nginx/canquest.conf)

NODE_ENV=production

# Browser calls /api/* on same domain (optional; BFF routes use relative /api)
NEXT_PUBLIC_API_URL=https://canquest.cc/api

# Next.js Route Handlers → Nest on localhost
INTERNAL_API_URL=http://127.0.0.1:3001/api

# Must EXACTLY match JWT_ACCESS_SECRET in apps/api/.env
# (Setelah migrasi Supabase: tetap dipakai untuk SSE token ephemeral.)
JWT_ACCESS_SECRET=CHANGE_ME_64_CHAR_HEX

# ─── Supabase Auth (Twitter OAuth provider — Connect X feature) ──────────────
# Dipakai untuk fitur "Connect X via OAuth" di Settings. Login/register utama
# tetap pakai flow BFF (cq_access cookie → Nest). NEXT_PUBLIC_* diekspos ke
# browser (anon key aman — RLS aktif). service_role TIDAK ada di frontend.
# Pastikan provider Twitter sudah di-enable di Supabase Auth settings dan
# callback URL di-set ke https://canquest.cc/api/twitter/oauth/callback.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...anon...
# Web origin dipakai redirect URL OAuth callback + reset password.
NEXT_PUBLIC_WEB_ORIGIN=https://canquest.cc

# Cloudflare Turnstile — set in apps/web/.env (NOT apps/api/.env)
# Site key: NEXT_PUBLIC_* (build) or TURNSTILE_SITE_KEY (runtime via /api/config/public)
# Secret: server-only, validates OTP/register on BFF routes
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# CC token icon — use API proxy (recommended; file lives in R2, key set on API VPS)
# NEXT_PUBLIC_CC_REWARD_LOGO_URL=https://api.canquest.cc/api/uploads/cc-reward-logo
# CC_REWARD_LOGO_URL=  # server-only; r2.dev URLs are auto-rewritten to API proxy

# Landing footer — social links (only set URLs appear in the footer)
# NEXT_PUBLIC_TWITTER_URL=https://x.com/canquest
# NEXT_PUBLIC_TELEGRAM_URL=https://t.me/canquest
# NEXT_PUBLIC_DISCORD_URL=https://discord.gg/your-invite
# NEXT_PUBLIC_BRAND_KIT_URL=https://link.to/brand-kit

# ─── Optional: Vercel-only deploy (web on Vercel, API on VPS 2) ───────────────
# NEXT_PUBLIC_API_URL=https://api.canquest.cc/api
# INTERNAL_API_URL=https://api.canquest.cc/api
