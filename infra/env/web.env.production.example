# ─── Vercel Environment Variables ─────────────────────────────────────────────
# Add these in: Vercel Dashboard → Project → Settings → Environment Variables
# Set environment: Production

# Public — visible in browser JS bundle
NEXT_PUBLIC_API_URL=https://api.canquest.cc/api

# Server-side only — used by Next.js Route Handlers to talk to NestJS
INTERNAL_API_URL=https://api.canquest.cc/api

# Must EXACTLY match JWT_ACCESS_SECRET in api.env.production
# Used by middleware to verify the auth cookie on the edge
JWT_ACCESS_SECRET=CHANGE_ME_64_CHAR_HEX
