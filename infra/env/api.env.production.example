NODE_ENV=production
PORT=3001

# Allow requests from both Vercel domains
WEB_ORIGIN=https://canquest.cc,https://app.canquest.cc,https://www.canquest.cc

# PostgreSQL on VPS 2 (local — never exposed externally)
# Must match the password you set in deploy.sh
DATABASE_URL=postgresql://canquest:CHANGE_ME_STRONG_PASSWORD@localhost:5432/canquest_app

# Run: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# Generate 3 different values — one for each secret below
JWT_ACCESS_SECRET=CHANGE_ME_64_CHAR_HEX
JWT_REFRESH_SECRET=CHANGE_ME_DIFFERENT_64_CHAR_HEX
ADMIN_JWT_SECRET=CHANGE_ME_ANOTHER_64_CHAR_HEX

# Invite codes (comma-separated). Leave empty = anyone can register
INVITE_CODES=

# Email OTP (Resend) — passwordless register/login
AUTH_REGISTER_SKIP_OTP=false
RESEND_API_KEY=re_CHANGE_ME
RESEND_FROM_EMAIL=Naxweb Verification <noreply@canquest.cc>

# Redis (local on VPS 2)
REDIS_URL=redis://localhost:6379

# ─── Canton JSON Ledger API ────────────────────────────────────────────────────
# Tunnel: VPS 2 (62.171.185.56) → validator VPS (IP depends on DevNet/TestNet/MainNet)
# See docs/NETWORK_TOPOLOGY.md — change SSH host in canton-tunnel.service when switching network
# Tunnel maps:
#   localhost:7575 → <participant_docker_ip>:7575  (Canton JSON Ledger API)
#   localhost:8080 → <nginx_docker_ip>:80          (Splice nginx — validator API + wallet UI)
#
# systemctl start canton-tunnel
# Verify: curl http://127.0.0.1:7575/livez  → 200 OK
CANTON_JSON_API_URL=http://127.0.0.1:7575

# ─── Splice Validator API ──────────────────────────────────────────────────────
# Splice nginx proxy (tunneled to port 80 of the nginx container on validator VPS).
# Exposes: /api/validator/v0/...  (wallet operations, user onboarding)
# Verify: curl http://127.0.0.1:8080/api/validator/v0/version
CANTON_VALIDATOR_URL=http://127.0.0.1:8080

# ─── Canton / Splice authentication ───────────────────────────────────────────
# Shared secret used to sign JWTs for both the Canton JSON API and the Splice
# Validator API (hs-256-unsafe mode used by testnet/mainnet validators).
#
# Find on the validator VPS for YOUR network (not DevNet if you use TestNet):
#   docker exec splice-validator-validator-1 env | grep -iE "secret|unsafe"
#   # or check: cat /path/to/canton.conf | grep secret
CANTON_SPLICE_SECRET=CHANGE_ME_SPLICE_SECRET

# Host header for nginx on validator VPS (required when tunneling to port 8080)
CANTON_VALIDATOR_HOST_HEADER=wallet.localhost

# JWT audience for the Canton JSON Ledger API (port 7575).
CANTON_LEDGER_API_AUDIENCE=https://canton.network.global

# JWT audience for the Splice Validator API (port 8080).
# DevNet: https://validator.example.com
# TestNet/MainNet: https://canton.network.global
CANTON_SPLICE_AUDIENCE=https://validator.example.com

# Ledger API user ID (must match the JWT sub used when granting party rights).
# Default is "ledger-api-user" — only change if your validator uses a different user.
CANTON_LEDGER_API_USER=ledger-api-user

# ─── Splice Validator node identity ───────────────────────────────────────────
# The admin username for the validator wallet (used to create transfer offers for rewards).
# Default is "administrator" for most Splice validator setups.
CANTON_VALIDATOR_ADMIN_USER=administrator

# The Canton Party ID of the validator node itself.
# Used to collect platform fees (send-cc endpoint).
# Find on the validator VPS for YOUR network (not DevNet if you use TestNet):
#   curl -s http://127.0.0.1:7575/v2/parties | jq '.partyDetails[].party'
#   # or: docker exec splice-validator-participant-1 curl -s http://localhost:7575/v2/parties
CANTON_VALIDATOR_PARTY_ID=CHANGE_ME_VALIDATOR_PARTY_ID

# ─── Platform fee configuration ───────────────────────────────────────────────
# CC fee charged per user-to-user transfer (sent to validator wallet as platform fee).
# Set to 0 to disable platform fees.
TRANSACTION_FEE_CC=5

# CC/USD exchange rate for display purposes only (does not affect transactions).
# Set to 0 if unknown.
CC_USD_PRICE=0

# Admin panel + bootstrap admin user email
ADMIN_EMAILS=admin@canquest.cc
ADMIN_PANEL_EMAIL=admin@canquest.cc
ADMIN_PANEL_PASSWORD=CHANGE_ME_STRONG_PASSWORD
ADMIN_JWT_SECRET=CHANGE_ME_ANOTHER_64_CHAR_HEX

# X (Twitter) task verification — https://twitterapi.io/dashboard
TWITTERAPI_IO_KEY=

# Quest on-chain (enable when DAML uploaded on validator)
QUEST_LEDGER_ENABLED=false
QUEST_SUBMIT_REQUIRES_WALLET=false
CANTON_DAML_PACKAGE_ID=
FEATURED_APP_MARKERS_ENABLED=false

# Inbound CC sync — record TRANSFER_IN when on-chain balance increases
CC_INBOUND_SYNC_ENABLED=true
CC_INBOUND_SYNC_POLL_MS=30000

# Ledger indexer (also watches all user party IDs from DB)
LEDGER_INDEXER_ENABLED=true
LEDGER_INDEXER_PARTY_IDS=
LEDGER_INDEXER_POLL_INTERVAL_MS=15000
