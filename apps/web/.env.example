# ── Next.js Web (apps/web) env example ──────────────────────────────────────
# Copy to apps/web/.env.local for local dev.

# Public origin (used by OAuth redirect URL builder).
NEXT_PUBLIC_WEB_ORIGIN=http://localhost:3000

# Internal NestJS API base URL (server-side only — used by BFF route handlers).
# Local dev: Nest default port. Production: VPS Nginx ingress.
INTERNAL_API_URL=http://127.0.0.1:3001

# ── Supabase Auth (Twitter OAuth provider) ─────────────────────────────────
# Dipakai HANYA untuk fitur "Connect X via OAuth" di Settings.
# Login/register Email+Password tetap pakai flow BFF (cq_access cookie → Nest).
# Dapatkan dari Supabase dashboard: Project Settings → API.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ── Cloudflare Turnstile (bot protection) ──────────────────────────────────
# Site key is public; secret stays server-side via apps/api.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
