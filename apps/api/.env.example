# Local environment — copy to `.env` and adjust.

NODE_ENV=development
PORT=3001
WEB_ORIGIN=http://localhost:3000

# PostgreSQL is used for both dev and production.
# Local dev: install PostgreSQL or run `docker compose up db` from /infra
DATABASE_URL=postgresql://canquest:canquest_dev@localhost:5432/canquest_dev

# Production (VPS 2):
# DATABASE_URL=postgresql://canquest:STRONG_PASSWORD@localhost:5432/canquest_app

JWT_ACCESS_SECRET=change-me-to-a-long-random-string-min-32-chars

# Invite codes — empty = no code required in development; comma-separated in production
INVITE_CODES=

# `true` = skip email OTP on register (dev only); remove/set false for real OTP flow
AUTH_REGISTER_SKIP_OTP=true

# Redis (Phase 2 — queues / cache)
REDIS_URL=redis://localhost:6379

# ─── Canton JSON Ledger API ────────────────────────────────────────────────────
#
# The participant container (splice-validator-participant-1) exposes port 7575
# as the Canton HTTP JSON Ledger API.
#
# From VPS 2, open an SSH tunnel to VPS 1:
#   ssh -N -L 7575:<PARTICIPANT_DOCKER_IP>:7575 user@VPS1_IP
#
# To find PARTICIPANT_DOCKER_IP on VPS 1:
#   docker inspect -f '{{range .NetworkSettings.Networks}}{{.IPAddress}}{{end}}' splice-validator-participant-1
#
# Or publish the port on VPS 1 (preferred, stable):
#   Add `ports: ["127.0.0.1:7575:7575"]` to participant in docker-compose.yaml on VPS 1
#   Then tunnel: ssh -N -L 7575:127.0.0.1:7575 user@VPS1_IP
#
# Verify: curl http://127.0.0.1:7575/livez   → should return 200
# Docs:   https://docs.digitalasset.com/build/3.5/tutorials/json-api/canton_and_the_json_ledger_api.html
#
CANTON_JSON_API_URL=http://127.0.0.1:7575
