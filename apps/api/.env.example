# Copy to apps/api/.env — set your validator IP (DevNet/TestNet/MainNet differ).
# Host IPs and topology live in a private runbook; do not commit them.


# --- APP + WEB ---

NODE_ENV=development
PORT=3001
WEB_ORIGIN=http://localhost:3000

DATABASE_URL=postgresql://canquest:canquest_dev@localhost:5432/canquest_dev

JWT_ACCESS_SECRET=change-me-min-32-chars

# ── Passkey (WebAuthn) — gate transaksi (Send/Swap/Lock/Unlock) ────────────
# Relying Party config. PASSKEY_RP_ID = domain web (tanpa protocol).
# WebAuthn ceremony ter-bound ke domain ini — harus match domain web yang serve app.
# Dev lokal (localhost): set PASSKEY_RP_ID=localhost, PASSKEY_ORIGIN=http://localhost:3000.
# Production: PASSKEY_RP_ID=canquest.cc, PASSKEY_ORIGIN=https://www.canquest.cc.
PASSKEY_RP_ID=canquest.cc
PASSKEY_ORIGIN=https://www.canquest.cc
PASSKEY_RP_NAME=CanQuest

# Secret for the OTP HMAC. If empty, falls back to JWT_ACCESS_SECRET.
# Set a random value >= 32 chars in production (e.g. `openssl rand -hex 32`).
OTP_HMAC_SECRET=

# --- SUPABASE (migrasi Auth + Database) ---
# Set SUPABASE_AUTH_ENABLED=true untuk beralih dari HS256 legacy ke Supabase Auth.
# false = mode rollback (login/register/refresh pakai sistem lama).
SUPABASE_AUTH_ENABLED=false
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
# service_role key — SERVER ONLY, tidak pernah ke browser. Bypass RLS.
SUPABASE_SERVICE_ROLE_KEY=eyJ...service-role...
# (opsional) anon key — tidak dipakai di API server, hanya untuk dokumentasi.
# SUPABASE_ANON_KEY=eyJ...anon...

# Setelah migrasi DB, ganti DATABASE_URL di atas ke direct connection Supabase:
# DATABASE_URL=postgresql://postgres:[DB-PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres

# Optional legacy — registration no longer requires platform invite codes
# INVITE_CODES=
# false = send 6-digit OTP email on register (requires Resend below)
AUTH_REGISTER_SKIP_OTP=false
# Resend — https://resend.com (verify domain canquest.cc in dashboard)
RESEND_API_KEY=
RESEND_FROM_EMAIL=Naxweb Verification <noreply@canquest.cc>
REFERRAL_REWARD_POINTS=20
# Wallet creation requires one-time admin-generated invite codes (no daily cap).

ADMIN_EMAILS=
ADMIN_PANEL_EMAIL=
# REQUIRED (security): Admin panel MUST use a distinct secret from user JWTs.
# If missing, or equal to JWT_ACCESS_SECRET, the app refuses to boot.
# Generate: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
ADMIN_JWT_SECRET=
ADMIN_PANEL_PASSWORD=
# REQUIRED for production (security): store a bcrypt hash, never plaintext.
# The plaintext ADMIN_PANEL_PASSWORD above is IGNORED when NODE_ENV=production.
# Generate a hash: node -e "console.log(require('bcrypt').hashSync('YOUR_PASSWORD', 12))"
ADMIN_PANEL_PASSWORD_HASH=

REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# Gate Earn (jalur points): biaya poin ikut satu campaign Earn (default 200).
# Bisa juga di-override live tanpa restart via AppSetting key `earn_entry_cost_points`.
EARN_ENTRY_COST_POINTS=200

# FCFS CC campaigns (CC_ONLY + max winners): on-chain claim fee before pool reward
FCFS_CLAIM_FEE_CC=3
# Abandoned FCFS reservations (distributed=false) expire after this many ms (default 5 min)
FCFS_RESERVATION_TTL_MS=300000
TRANSACTION_FEE_CC=2
# Validator treasury on ccview / Splice (party may differ from ledger hint "administrator::...")
# CANTON_VALIDATOR_PARTY_ID=naxweb-validator-1::1220cc5c...
# CANTON_FEE_RECIPIENT_PARTY_ID=naxweb-validator-1::1220cc5c...
# Splice wallet user that owns treasury party (user-status → party_id)
# CANTON_FEE_ACCEPT_USERNAME=administrator
CC_USD_PRICE=0

# --- Cloudflare R2 (Earn campaign banner + logo) ---
# Dashboard: R2 bucket → Settings → Public access (or custom domain) for R2_PUBLIC_BASE_URL
# S3 API token: Account → R2 → Manage API tokens (Object Read & Write)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
# Optional — if set, upload also verifies this pub/custom URL (Earn still uses API proxy below)
R2_PUBLIC_BASE_URL=
# Optional override (default https://{R2_ACCOUNT_ID}.r2.cloudflarestorage.com)
# R2_ENDPOINT=
# Max upload size per image (bytes, default 5MB)
# QUEST_MEDIA_MAX_BYTES=5242880
# Required on VPS for quest image URLs returned to the web app
API_PUBLIC_BASE_URL=https://api.canquest.cc
# R2 object key for CC reward icon (served at GET /api/uploads/cc-reward-logo)
CC_REWARD_LOGO_R2_KEY=quests/C (1).png


# --- CANTON ---
# DEV (this file): SSH tunnel to validator node. CANTON_VALIDATOR_URL=http://127.0.0.1:8080,
#   CANTON_VALIDATOR_HOST_HEADER=wallet.localhost (nginx server_name routing).
# PROD: pakai gateway publik + TLS. Set di apps/api/.env:
#   CANTON_VALIDATOR_URL=https://api-canquest.nodelab.my.id
#   CANTON_VALIDATOR_HOST_HEADER=   (KOSONG — gateway route via SNI, bukan wallet.localhost)
#   CANTON_SCAN_URL=https://api-canquest.nodelab.my.id/api/validator/v0/scan-proxy
#   LEDGER_API_URL=https://api-ledger-canquest.nodelab.my.id  (lihat §Keycloak di bawah)
# Hapus SSH tunnel sepenuhnya di prod (sudah tidak dipakai sejak LEDGER_AUTH_MODE=keycloak).

CANTON_JSON_API_URL=http://127.0.0.1:7575
# HS256 shared secret — ONLY for local devnet/testnet (LEDGER_AUTH_MODE=hs256).
# Production uses Keycloak (LEDGER_AUTH_MODE=keycloak) and MUST leave this EMPTY.
# Never commit a real secret. A random >=32-byte value (e.g. `openssl rand -hex 32`)
# is required in any non-dev environment that still uses hs256.
CANTON_SPLICE_SECRET=
CANTON_LEDGER_API_AUDIENCE=https://canton.network.global
CANTON_LEDGER_API_USER=ledger-api-user

CANTON_VALIDATOR_URL=http://127.0.0.1:8080
CANTON_VALIDATOR_HOST_HEADER=wallet.localhost
# Audience for the HS256 wallet JWT. Only relevant when LEDGER_AUTH_MODE=hs256.
CANTON_SPLICE_AUDIENCE=https://canton.network.global
CANTON_VALIDATOR_ADMIN_USER=administrator

CANTON_VALIDATOR_PARTY_ID=
CANTON_APP_PROVIDER_PARTY_ID=
CANTON_OPERATOR_PARTY_ID=
# Web2 quest mode — see docs/ARCHITECTURE_LAYERS.md
QUEST_LEDGER_ENABLED=false
FEATURED_APP_MARKERS_ENABLED=false
QUEST_SUBMIT_REQUIRES_WALLET=false

# X (Twitter) task verification — https://twitterapi.io/
TWITTERAPI_IO_KEY=

# Twitter API cache (Redis) — anti-boros kuota twitterapi.io.
# Default memakai REDIS_HOST/PORT/PASSWORD di atas (sama seperti BullMQ).
# Bila Redis tidak tersedia/down, cache otomatis di-skip — verify tetap jalan.
# Set TWITTER_CACHE_ENABLED=false untuk matikan cache sepenuhnya.
TWITTER_CACHE_ENABLED=true
TWITTER_CACHE_KEY_PREFIX=tcache
# Package name for template refs (#canquest-v2:Module:Template) — required for ACS queries on Canton 3.x
CANTON_DAML_PACKAGE_NAME=canquest-v2
CANTON_DAML_PACKAGE_ID=

CC_INBOUND_SYNC_ENABLED=true
CC_INBOUND_SYNC_POLL_MS=30000

# --- Ledger auth mode ---
# Pick ONE: 'keycloak' | 'hs256' (legacy, dev only).
# Production uses Keycloak. Do NOT duplicate this variable below.
LEDGER_AUTH_MODE=keycloak

# --- Keycloak OIDC (LEDGER_AUTH_MODE=keycloak) ---
# Production: oauth-canquest.nodelab.my.id (realm: canton).
KEYCLOAK_URL=https://oauth-canquest.nodelab.my.id
KEYCLOAK_REALM=canton
LEDGER_API_AUTH_SCOPE=daml_ledger_api
# validator-app-backend client in realm canton (client_credentials grant).
LEDGER_CLIENT_ID=validator-app-backend
# required — NEVER commit a real secret. Set only in apps/api/.env.
LEDGER_CLIENT_SECRET=
# Optional separate reward client; falls back to LEDGER_CLIENT_* when unset.
REWARD_CLIENT_ID=
REWARD_CLIENT_SECRET=
LEDGER_API_URL=https://api-ledger-canquest.nodelab.my.id
# required — master-realm admin-cli credentials for user management API.
KEYCLOAK_ADMIN_USER=
KEYCLOAK_ADMIN_PASSWORD=
LEDGER_ADMIN_USER_ID=

# Balance API: PostgreSQL first, Splice sync in background (reduces tunnel load)
BALANCE_READ_FROM_DB=true
BALANCE_DB_MAX_AGE_MS=60000
BALANCE_BACKGROUND_DEBOUNCE_MS=15000

# NOTE: tx explorer + onchain transaction history pakai Modo API (api.modo.link).
# Explorer link: https://cc.modo.link/mainnet/updates/{id} (dibangun di ModoApiService).
# CANTON_SCAN_TX_URL tidak lagi dipakai untuk link explorer transaksi.
MODO_API_URL=https://api.modo.link/canton-mainnet
MODO_API_KEY=your-modo-api-key
LEDGER_INDEXER_ENABLED=false
LEDGER_INDEXER_PARTY_IDS=
LEDGER_INDEXER_POLL_INTERVAL_MS=15000

# ── CC LOCK — Spec CC Lock (CC stays owned by user's party; returned at expiry) ──
# Format: label:detik dipisah koma. UI render opsi dari sini (BUKAN hard-code).
LOCK_TERM_OPTIONS=7d:604800,15d:1296000,30d:2592000
# Holder lock LockedAmulet (opsional; kosong → fallback CANTON_VALIDATOR_PARTY_ID)
CANTON_LOCK_HOLDER_PARTY=
# Ambang tier eligibility (CC terkunci): ≥FULL → boleh ikut Earn.
LOCK_TIER_FULL=30
