# Local environment — copy to `.env` and adjust.

NODE_ENV=development
PORT=3001
WEB_ORIGIN=http://localhost:3000

# PostgreSQL is used for both dev and production.
# Local dev: install PostgreSQL or run `docker compose up db` from /infra
DATABASE_URL=postgresql://canquest:canquest_dev@localhost:5432/canquest_dev

# Production (VPS 2):
# DATABASE_URL=postgresql://canquest:STRONG_PASSWORD@localhost:5432/canquest_app

JWT_ACCESS_SECRET=change-me-to-a-long-random-string-min-32-chars

# Invite codes — empty = no code required in development; comma-separated in production
INVITE_CODES=

# `true` = skip email OTP on register (dev only); remove/set false for real OTP flow
AUTH_REGISTER_SKIP_OTP=true

# Redis (Phase 2 — queues / cache)
REDIS_URL=redis://localhost:6379

# ─── Canton JSON Ledger API ────────────────────────────────────────────────────
#
# The participant container (splice-validator-participant-1) exposes port 7575.
# Open an SSH tunnel from your machine to your validator VPS:
#   ssh -N -L 7575:<PARTICIPANT_DOCKER_IP>:7575 user@VPS1_IP
#
# Verify: curl http://127.0.0.1:7575/livez   → should return 200
# Docs:   https://docs.digitalasset.com/build/3.5/tutorials/json-api/canton_and_the_json_ledger_api.html
#
CANTON_JSON_API_URL=http://127.0.0.1:7575

# ─── Splice Validator API ──────────────────────────────────────────────────────
# The Splice nginx container proxies the validator API on port 80.
# Tunnel: ssh -N -L 8080:<NGINX_DOCKER_IP>:80 user@VPS1_IP
# Verify: curl http://127.0.0.1:8080/api/validator/v0/version
CANTON_VALIDATOR_URL=http://127.0.0.1:8080

# ─── Canton / Splice authentication ───────────────────────────────────────────
# Shared secret for JWT signing (hs-256-unsafe mode).
# Find on your validator VPS: docker exec splice-validator-validator-1 env | grep -iE "secret|unsafe"
CANTON_SPLICE_SECRET=unsafe

# JWT audience for the Canton JSON Ledger API (port 7575).
CANTON_LEDGER_API_AUDIENCE=https://canton.network.global

# JWT audience for the Splice Validator API.
CANTON_SPLICE_AUDIENCE=https://canton.network.global

# Ledger API user — usually "ledger-api-user" (default, do not change unless required).
CANTON_LEDGER_API_USER=ledger-api-user

# ─── Splice Validator node identity ───────────────────────────────────────────
# Admin username for the validator wallet (used when distributing rewards).
CANTON_VALIDATOR_ADMIN_USER=administrator

# Party ID of your validator node (for platform fee collection). Leave empty to disable fees.
CANTON_VALIDATOR_PARTY_ID=

# ─── Platform fee configuration ───────────────────────────────────────────────
TRANSACTION_FEE_CC=5
CC_USD_PRICE=0
