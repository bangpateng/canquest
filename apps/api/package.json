{
  "name": "api",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "npm run prisma:generate && npx nest build && node -e \"require('fs').accessSync('dist/main.js')\"",
    "build:api": "npm run build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "node -r ./register-module-path.cjs ./node_modules/@nestjs/cli/bin/nest.js start",
    "start:dev": "node -r ./register-module-path.cjs ./node_modules/@nestjs/cli/bin/nest.js start --watch",
    "prisma:generate": "cross-env PRISMA_CLIENT_ENGINE_TYPE=binary PRISMA_CLI_QUERY_ENGINE_TYPE=binary npx prisma generate",
    "prisma:migrate": "cross-env PRISMA_CLIENT_ENGINE_TYPE=binary PRISMA_CLI_QUERY_ENGINE_TYPE=binary npx prisma migrate dev",
    "prisma:push": "cross-env PRISMA_CLIENT_ENGINE_TYPE=binary PRISMA_CLI_QUERY_ENGINE_TYPE=binary npx prisma db push",
    "start:debug": "node -r ./register-module-path.cjs ./node_modules/@nestjs/cli/bin/nest.js start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "canton:check": "node scripts/check-canton-connectivity.cjs",
    "demo:seed": "node scripts/seed-reward-demo-quests.cjs --replace",
    "demo:users": "node scripts/create-demo-test-users.cjs",
    "demo:e2e": "node scripts/e2e-reward-demos.cjs --admin-draw",
    "demo:dedupe-txs": "node scripts/dedupe-quest-wallet-txs.cjs",
    "canton:get-validator-party": "node scripts/get-validator-party-id.cjs",
    "quest:operator": "node scripts/ensure-quest-operator.cjs canquest-operator",
    "daml:build": "docker run --rm -v \"../../packages/daml:/project\" -w /project digitalasset/daml-sdk:3.3.0-snapshot.20250930.0 bash -lc \"/home/daml/.daml/bin/daml build\"",
    "daml:inspect": "docker run --rm -v \"../../packages/daml:/project\" -w /project digitalasset/daml-sdk:3.3.0-snapshot.20250930.0 bash -lc \"/home/daml/.daml/bin/daml damlc inspect-dar .daml/dist/canquest-v2-0.1.0.dar\"",
    "daml:upload": "node scripts/upload-daml-dar.cjs",
    "daml:verify": "node scripts/verify-daml-package.cjs"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1053.0",
    "@nestjs/bull": "^11.0.4",
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.0.1",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/throttler": "^6.5.0",
    "@noble/ed25519": "^2.3.0",
    "@noble/hashes": "^1.8.0",
    "@noble/secp256k1": "^2.3.0",
    "@prisma/client": "^6.19.3",
    "@simplewebauthn/server": "^10.0.1",
    "@supabase/supabase-js": "2.49.10",
    "@types/bull": "^3.15.9",
    "bcrypt": "^6.0.0",
    "bull": "^4.16.5",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "express": "^5.1.0",
    "google-auth-library": "^10.9.0",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.21",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@types/bcrypt": "^6.0.0",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/multer": "^2.1.0",
    "@types/node": "^24.0.0",
    "@types/passport-jwt": "^4.0.1",
    "@types/supertest": "^7.0.0",
    "@types/ws": "^8.18.1",
    "cross-env": "^10.1.0",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^17.0.0",
    "jest": "^30.0.0",
    "prettier": "^3.4.2",
    "prisma": "^6.19.3",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
