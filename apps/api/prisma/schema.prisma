generator client {
  provider = "prisma-client-js"
}

// PostgreSQL (Supabase Postgres cloud).
// Local dev: install PostgreSQL locally or run `docker compose up db` from /infra.
// Production: Supabase cloud — runtime pakai pooler PgBouncer port 6543
//   (DATABASE_URL), migration pakai direct connection port 5432 (DIRECT_URL)
//   supaya tidak kena error P1001/P2024 saat prisma migrate.
datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

/// Application state: auth, quests, earn entries, etc.
model User {
  id                      String                @id @default(cuid())
  email                   String                @unique
  displayName             String?
  /// Relative path under uploads root, e.g. avatars/{userId}.jpg
  avatarPath              String?
  passwordHash            String
  inviteCode              String?
  /// Unique code this user shares for friend referrals (e.g. CQ8X4K2M).
  referralCode            String?               @unique
  /// Set when the user registered with someone else's referralCode.
  referredById            String?
  referredBy              User?                 @relation("UserReferrals", fields: [referredById], references: [id], onDelete: SetNull)
  referredUsers           User[]                @relation("UserReferrals")
  emailVerified           Boolean               @default(false)
  otpCodeHash             String?
  otpExpiresAt            DateTime?
  /// Failed OTP verification attempts for the current pending code. Reset to 0 on each new code; >=5 clears the OTP.
  otpAttempts             Int                   @default(0)
  username                String?               @unique
  /// Canton ledger party identifier after binding — follow Participant / Ledger API contracts.
  /// SECURITY (H6): @unique enforces 1 wallet ↔ 1 account at the DB level. Without
  /// this, a single Canton wallet could be bound to many accounts, letting one
  /// attacker claim quest rewards / FCFS slots / raffle entries N times via N
  /// email accounts sharing one funded wallet. The app-layer findByPartyId check
  /// in party.controller is a TOCTOU guard; this constraint is the source of truth.
  cantonPartyId           String?               @unique
  /// Keycloak user UUID (sub) — identity bridge between web2 User and on-chain Ledger API user.
  keycloakId              String?               @unique
  /// Last time user toggled preapproval (enable/disable). Cooldown 7 hari anti-spam burn.
  preapprovalToggleAt     DateTime?
  /// Admin flag — set via ADMIN_EMAILS env or manually.
  isAdmin                 Boolean               @default(false)
  /// Account access status (ACTIVE = full access). Additive — defaults ACTIVE so existing users are unaffected.
  status                  UserStatus            @default(ACTIVE)
  /// Timestamp of the most recent ban/suspend (null when ACTIVE).
  bannedAt                DateTime?
  /// Admin-supplied reason for the current ban/suspend (null when ACTIVE).
  banReason               String?
  /// Lifetime earn points (quest/earn tasks, completion bonus, referral) — synced via PointsService.
  earnPoints              Int                   @default(0)
  /// Linked X (Twitter) handle for social task verification (twitterapi.io).
  twitterUsername         String?               @unique
  twitterUserId           String?
  /// High-res X avatar URL (pbs.twimg.com, _400x400) — not stored on VPS disk.
  twitterAvatarUrl        String?
  twitterConnectedAt      DateTime?
  /// Last time the user opened or dismissed in-app CC notifications (bell).
  notificationsLastSeenAt DateTime?
  /// bcrypt hash kata sandi transaksi opsional (gate Send/Lock/Unlock). Null = tidak ada gate.
  walletPasswordHash       String?
  /// Penghitung percobaan verifikasi gagal — reset ke 0 saat berhasil / saat set password baru.
  walletPasswordAttempts   Int                   @default(0)
  /// Sampai kapan verifikasi dikunci karena terlalu banyak percobaan gagal (null = tidak terkunci).
  walletPasswordLockedUntil DateTime?
  createdAt               DateTime              @default(now())
  updatedAt               DateTime              @updatedAt
  refreshTokens           RefreshToken[]
  passwordResets          PasswordReset[]       @relation("UserPasswordResets")
  ccBalance               CcBalance?
  ccTransactions          CcTransaction[]
  questCompletions        QuestCompletion[]
  questSubmissions        QuestSubmission[]
  winnerDraws             WinnerDraw[]
  assignedCodes           InviteCodePool[]
  referralRewardsGiven    ReferralReward[]      @relation("ReferralRewardsGiven")
  referralRewardReceived  ReferralReward?       @relation("ReferralRewardReceived")
  walletAllocations       WalletAllocationLog[]
  redeemedWalletInvites   WalletInviteCode[]    @relation("WalletInviteRedemptions")
  ccLocks                 CcLock[]
  earnEntries             EarnEntry[]
  /// Off-chain custody: saldo token non-CC user di Cantex trading account shared.
  cantexTokenBalances     CantexTokenBalance[]
  /// Riwayat P2P transfer token non-CC on-chain (CIP-0056 two-step).
  tokenTransactions       TokenTransaction[]
  /// Riwayat swap CC ↔ token Cantex DEX.
  swapTransactions        SwapTransaction[]
  /// Delivery token/CC tertunda dari swap yang gagal di-deliver on-chain.
  pendingDeliveries       PendingDelivery[]
  /// OAuth / external identity links (Google, dst). 1 user bisa banyak provider.
  accounts                Account[]
}

/// OAuth account link — binds a User to an external identity provider.
/// providerAccountId = provider's stable, immutable subject (e.g. Google `sub`),
/// BUKAN email. Email cuma snapshot untuk audit.
model Account {
  id                String   @id @default(cuid())
  userId            String
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// "google" | "apple" | dst.
  provider          String
  /// Stable immutable subject from provider (Google sub, Apple sub).
  providerAccountId String
  /// Snapshot email saat link (audit only — identity source-of-truth = sub).
  email             String
  linkedAt          DateTime @default(now())

  @@unique([provider, providerAccountId])
  @@index([userId])
}

/// Catatan partisipasi user di campaign Earn — sekaligus sumber pengurang poin
/// (menggantikan SpinResult sebagai satu-satunya tempat poin terpotong).
/// Satu baris per (user, quest): gate Earn berlaku per-campaign.
model EarnEntry {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  questId       String
  /// Metode akses yang dipakai: 'points' | 'cc_lock' | 'none' (mode gate NONE / event gratis)
  method        String
  /// Poin terpotong (0 jika method = cc_lock)
  pointsSpent   Int      @default(0)
  /// CC yang dikunci/terpakai dalam micro-CC (0 jika method = points)
  ccLockedMicro BigInt   @default(0)
  /// true jika lock CC sudah dikembalikan (khusus jalur escrow cc_lock)
  released      Boolean  @default(false)
  createdAt     DateTime @default(now())

  @@unique([userId, questId])
  @@index([questId])
}

/// One-time codes required to create a Canton wallet (admin-generated).
/// Consumed only after a real wallet is created (redeemedAt set). Failed attempts release the reservation.
model WalletInviteCode {
  id           String    @id @default(cuid())
  code         String    @unique
  note         String?
  createdAt    DateTime  @default(now())
  redeemedAt   DateTime?
  redeemedById String?
  redeemedBy   User?     @relation("WalletInviteRedemptions", fields: [redeemedById], references: [id], onDelete: SetNull)
  /// Temporary hold while user is creating a wallet (not consumed until success).
  reservedById String?
  reservedAt   DateTime?

  @@index([redeemedAt])
  @@index([reservedById])
  @@index([createdAt])
}

/// Global daily counter — each row is one Canton/Splice wallet slot consumed (UTC day).
model WalletAllocationLog {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  username  String?
  partyId   String
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([userId])
}

/// One row per successful referred signup (referrer credited once).
model ReferralReward {
  id             String   @id @default(cuid())
  referrerId     String
  referrer       User     @relation("ReferralRewardsGiven", fields: [referrerId], references: [id], onDelete: Cascade)
  referredUserId String   @unique
  referredUser   User     @relation("ReferralRewardReceived", fields: [referredUserId], references: [id], onDelete: Cascade)
  points         Int
  createdAt      DateTime @default(now())

  @@index([referrerId])
}

model RefreshToken {
  id        String    @id @default(cuid())
  tokenHash String    @unique
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())
}

/// One-time 6-digit password reset codes (HMAC-SHA256 hashed) — separate from email OTP.
/// Anti-enumeration: forgot-password always replies generically; only stored when user exists.
model PasswordReset {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation("UserPasswordResets", fields: [userId], references: [id], onDelete: Cascade)
  codeHash  String // HMAC-SHA256(secret, `reset:${userId}:${code}`)
  expiresAt DateTime
  attempts  Int       @default(0)
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
}

/// Tracks CC token balance for each user (off-chain mirror of Canton ledger).
/// Settled to the actual Splice ledger periodically or on withdrawal.
model CcBalance {
  id             String   @id @default(cuid())
  userId         String   @unique
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// Total CC balance in micro-CC (1 CC = 1_000_000 micro-CC) to avoid float precision issues.
  balanceMicroCc BigInt   @default(0)
  updatedAt      DateTime @updatedAt
}

/// Every CC credit/debit event — full audit trail.
model CcTransaction {
  id                     String            @id @default(cuid())
  userId                 String
  user                   User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// Positive = credit, negative = debit (in micro-CC).
  amountMicroCc          BigInt
  type                   CcTransactionType
  /// Human-readable description, e.g. "Quest reward: Daily Login"
  description            String
  /// Reference to the source (questId, earnEntryId, etc.)
  referenceId            String?
  /// Offer / contract ID on Canton (e.g. TransferOffer contract).
  ledgerTxId             String?
  /// Ledger update ID from submit-and-wait / transaction stream (CantonScan).
  cantonUpdateId         String?
  status                 String            @default("COMPLETED") // COMPLETED | PENDING | REJECTED
  transferInstructionCid String?
  settledAt              DateTime?
  createdAt              DateTime          @default(now())

  /// Jumlah asli (CC) yang dibatalkan/ditolak — hanya diisi untuk OFFER_WITHDRAWN /
  /// OFFER_REJECTED. Saldo tidak bergerak (amountMicroCc=0), tapi amount asli
  /// offer disimpan di sini agar Activity & badge bisa menampilkan "cancelled 5 CC".
  cancelledAmountCc      Decimal?          @db.Decimal(20, 10)
  /// Instrument id token (mis. "USDCx") bila offer yang dibatalkan adalah token.
  cancelledInstrumentId  String?

  @@unique([userId, ledgerTxId])
  @@index([cantonUpdateId])
  @@index([transferInstructionCid])
}

enum CcTransactionType {
  QUEST_REWARD
  SPIN_REWARD
  TRANSFER_IN
  TRANSFER_OUT
  AIRDROP
  CC_LOCK
  CC_UNLOCK
  /// Receiver menolak incoming TransferInstruction (onchain exercise).
  OFFER_REJECTED
  /// Sender menarik kembali TransferInstruction yang belum di-accept.
  OFFER_WITHDRAWN
  /// User mengaktifkan TransferPreapproval (onchain create, burn fee).
  PREAPPROVAL_ENABLED
  /// User menonaktifkan TransferPreapproval (onchain archive).
  PREAPPROVAL_DISABLED
  /// CC keluar dari party user menuju Cantex trading account (swap CC → token).
  SWAP_OUT
  /// CC masuk ke party user dari Cantex trading account (swap token → CC).
  SWAP_IN
}

/// Off-chain custody untuk token non-CC (Cantex DEX). Token asli berada di
/// Cantex trading account yang shared (cantex::1220c6...); CanQuest mencatat
/// kepemilikan per-user di sini (model custodial Wintip-style).
/// Saldo pakai Decimal(38,18) karena Cantex API memakai decimal-string amounts.
model CantexTokenBalance {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// Cantex instrument id, mis. "TokenX" / "Amulet".
  instrumentId    String
  /// Cantex instrument admin party, mis. "DSO::1220...".
  instrumentAdmin String
  /// Saldo human-decimal (bukan micro-units).
  balance         Decimal  @default(0) @db.Decimal(38, 18)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([userId, instrumentId, instrumentAdmin])
  @@index([userId])
}

/// Riwayat P2P transfer token non-CC on-chain (CIP-0056 two-step).
/// CcTransaction strictly CC (amountMicroCc, no instrument field) — menumpang
/// amount token non-CC di situ akan corrupt audit trail & reconcile CC. Model
/// ini instrument-aware: amount pakai Decimal(38,18) sesuai Cantex API.
///
/// Sumber kebenaran saldo token = ON-CHAIN (queryTokenHoldings). CantexTokenBalance
/// (DB) jadi cache/UI-only — BUKAN dipakai untuk validate send-token.
model TokenTransaction {
  id                     String       @id @default(cuid())
  userId                 String
  user                   User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// Cantex instrument id, mis. "USDCX", "TokenX". "Amulet" jika dipakai untuk CC.
  instrumentId           String
  /// Cantex instrument admin party, mis. "DSO::1220...".
  instrumentAdmin        String
  /// Jumlah token (positive = credit masuk, negatif = debit keluar). Decimal-string compatible.
  amount                 Decimal      @db.Decimal(38, 18)
  type                   TokenTxType
  description            String?
  /// Reference (counterparty party id, contract id, dsb).
  referenceId            String?
  /// Offer / contract ID on Canton (TransferInstruction contract id).
  ledgerTxId             String?
  /// Ledger update ID dari submit-and-wait (CantonScan link).
  cantonUpdateId         String?
  transferInstructionCid String?
  status                 String       @default("COMPLETED") // COMPLETED | PENDING | REJECTED
  createdAt              DateTime     @default(now())

  /// Jumlah asli (token) yang dibatalkan/ditarik — hanya diisi untuk
  /// TOKEN_OFFER_WITHDRAWN / TOKEN_OFFER_REJECTED. Saldo tidak bergerak (amount=0),
  /// tapi amount asli offer disimpan di sini agar Activity & badge bisa menampilkan
  /// "cancelled 5 USDCx".
  cancelledAmount        Decimal?     @db.Decimal(38, 18)

  @@unique([userId, ledgerTxId])
  @@index([cantonUpdateId])
  @@index([transferInstructionCid])
  @@index([userId, instrumentId, instrumentAdmin])
}

/// Tipe event TokenTransaction (P2P token transfer on-chain, CIP-0056).
enum TokenTxType {
  /// Sender mengirim token (offer dibuat di on-chain).
  TOKEN_TRANSFER_OUT
  /// Receiver menerima token setelah accept TransferInstruction.
  TOKEN_TRANSFER_IN
  /// Offer dibuat, menunggu accept (intermediate state, opional).
  TOKEN_OFFER_PENDING
  /// Receiver menolak TransferInstruction (token kembali ke sender).
  TOKEN_OFFER_REJECTED
  /// Sender menarik kembali TransferInstruction yang belum di-accept.
  TOKEN_OFFER_WITHDRAWN
  /// Fee CC keluar untuk P2P token transfer (fee in CC, reuse TRANSACTION_FEE_CC).
  TOKEN_FEE_OUT
}

/// Audit trail lengkap untuk setiap swap CC ↔ token Cantex DEX (multi-leg).
model SwapTransaction {
  id                  String   @id @default(cuid())
  userId              String
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// "CC_TO_TOKEN" (swap CC → token) | "TOKEN_TO_CC" (swap token → CC).
  direction           String
  /// Instrumen yang dijual.
  sellInstrumentId    String
  sellInstrumentAdmin String
  sellAmount          Decimal  @db.Decimal(38, 18)
  /// Instrumen yang dibeli.
  buyInstrumentId     String
  buyInstrumentAdmin  String
  /// Jumlah yang dibeli — null sampai Cantex SwapExecuted event diterima.
  buyAmount           Decimal? @db.Decimal(38, 18)
  /// Cantex pool contract id (opsional, untuk referensi).
  poolContractId      String?
  /// id dari /v1/intent/build/pool/swap (build response).
  cantexSubmissionId  String?
  /// Canton update id untuk leg CC (transfer user↔trading account).
  ccLedgerTxId        String?
  /// PENDING (sedang diproses) | EXECUTED (sukses) | FAILED (gagal).
  status              String   @default("PENDING")
  /// Idempotency key dari client — mencegah double-submit swap yang sama.
  clientNonce         String   @unique
  swapExecutedAt      DateTime?
  errorMessage        String?
  createdAt           DateTime @default(now())

  /// Delivery tertunda bila token/CC gagal dikirim on-chain ke user.
  pendingDeliveries   PendingDelivery[]

  @@index([userId, createdAt])
}

/// CC Lock (non-custodial) — metadata untuk LockedAmulet on-chain.
/// Jumlah terkunci (sumber kebenaran) tetap dari on-chain (findLockedAmulets /
/// effective_locked_qty); tabel ini hanya untuk term, kapan boleh unlock, cid, audit + UI.
/// Spec CC Lock — CanQuest.
model CcLock {
  id              String    @id @default(cuid())
  ownerParty      String // party id user (mis. verify::1220...)
  userId          String? // id user dapp (untuk join), jika ada
  user            User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  amountCc        Decimal   @db.Decimal(20, 10)
  termKey         String // mis. "15d" atau "5m" (uji)
  lockSeconds     Int // durasi efektif dalam detik
  lockedAt        DateTime  @default(now())
  expiresAt       DateTime // lockedAt + lockSeconds
  status          String    @default("LOCKED") // LOCKED | UNLOCKED
  lockedAmuletCid String?
  unlockedAt      DateTime?
  createdAt       DateTime  @default(now())

  @@index([ownerParty, status])
}

/// Quest campaign dibuat oleh admin/operator.
model Quest {
  id               String            @id @default(cuid())
  title            String
  /// Short partner name for social task titles (Follow X, Join Discord, etc.). Falls back to title when empty.
  projectName      String?
  org              String
  orgSlug          String
  description      String
  banner           String            @default("linear-gradient(135deg,#1e293b,#0f172a)")
  /// Optional image URL (e.g. /quest-media/uuid.webp) shown as quest card/header banner; overrides gradient when set.
  bannerImageUrl   String?
  /// Square project logo; falls back to org initials when absent.
  logoUrl          String?
  rewardCc         Float             @default(0)
  rewardPool       String            @default("0 CC")
  deadline         String?
  /// Optional ISO timeline — quest hidden before startsAt / after endsAt when set.
  startsAt         DateTime?
  endsAt           DateTime?
  status           QuestStatus       @default(ACTIVE)
  tags             String            @default("[]")
  /// JSON array of { platform, url } — shown under About on campaign detail (admin-configured).
  socialLinks      String            @default("[]")
  /// Reward category: waitlist email, random invite, FCFS invite, CC, or CC + invite
  rewardType       RewardType        @default(CC_ONLY)
  /// Max number of winners (null = unlimited / all completers rewarded)
  maxWinners       Int?
  /// CC_AND_CODE_RAFFLE: berapa pemenang yang dapat CODE (sisanya dapat CC). Null = semua pemenang dapat keduanya (perilaku lama).
  codeWinnersQuota Int?
  /// On-chain claim fee (CC) before user receives code/CC; null = use reward-type default (2 code / 3 token FCFS).
  claimFeeCc       Float?
  /// Custom message shown to raffle/email winners (admin dashboard).
  winnerMessage    String?
  /// Link register/landing proyek untuk redeem code (shown in "How to use your code" reveal).
  redeemUrl        String?
  /// Instruksi custom redeem (multi-line). Kosong = pakai template 3-step default (Register → Use code → Done).
  redeemInstructions String?
  /// CAMPAIGN = partner campaigns (user menu Earn). EARN_HUB = CanQuest daily tasks (user menu Quest).
  questKind        QuestKind         @default(CAMPAIGN)
  /// DAML QuestCampaign contract ID on Canton ledger (set after admin creates quest).
  /// Used by claimFcfsSlot() / drawRaffleWinner() to reference the on-chain campaign.
  ledgerCampaignId String?
  /// Mode gate akses Earn per-campaign (configurable dari dashboard admin).
  /// CC_OR_POINTS (default) = lock CC atau spend points (perilaku lama).
  /// CC_ONLY / POINTS_ONLY / NONE = admin pilih per-event.
  entryGateMode    EntryGateMode     @default(CC_OR_POINTS)
  /// Override jumlah CC yang harus di-lock (jalur cc_lock). Null = pakai default global (LOCK_TIER_FULL, 30).
  entryCcLock      Int?
  /// Override biaya points (jalur points). Null = pakai default global (earn_entry_cost_points AppSetting / 200).
  entryCostPoints  Int?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  tasks            QuestTask[]
  completions      QuestCompletion[]
  submissions      QuestSubmission[]
  inviteCodes      InviteCodePool[]
  winnerDraws      WinnerDraw[]
}

enum RewardType {
  WAITLIST_EMAIL
  INVITE_CODE_RANDOM
  INVITE_CODE_FCFS
  CC_ONLY
  /// Raffle CC — admin draw after event; winners claim on-chain
  CC_MANUAL
  CC_AND_INVITE
  /// Combined raffle: winners get both CC reward AND an invite code in one event; each claim costs 5 CC
  CC_AND_CODE_RAFFLE
  /// @deprecated Use INVITE_CODE_RANDOM — kept for existing rows
  INVITE_CODE
}

/// Pool of invite codes for a quest (admin uploads these).
model InviteCodePool {
  id         String    @id @default(cuid())
  questId    String
  quest      Quest     @relation(fields: [questId], references: [id], onDelete: Cascade)
  code       String    @unique
  /// Assigned to this user (null = not yet distributed)
  userId     String?
  user       User?     @relation(fields: [userId], references: [id])
  assignedAt DateTime?
  createdAt  DateTime  @default(now())
}

/// Records winner selection for a quest draw.
model WinnerDraw {
  id                     String    @id @default(cuid())
  questId                String
  quest                  Quest     @relation(fields: [questId], references: [id], onDelete: Cascade)
  userId                 String
  user                   User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// CC amount that was (or will be) sent to this winner
  ccAmount               Float     @default(0)
  /// Invite code assigned (if applicable)
  inviteCode             String?
  /// CC_AND_CODE_RAFFLE: varian reward pemenang — 'CODE' atau 'CC'. Null = varian lama (keduanya) untuk kompatibilitas.
  rewardVariant          String?
  /// Whether the reward has been distributed on-chain
  distributed            Boolean   @default(false)
  /// Canton ledger TX id after CC distribution
  ledgerTxId             String?
  /// TransferOffer id for user-paid claim fee (invite/code or FCFS claim).
  claimFeeLedgerTxId     String?
  /// DAML ClaimSession contract id (audit/state machine).
  claimSessionContractId String?
  drawnAt                DateTime  @default(now())
  distributedAt          DateTime?
  /// Set while on-chain FCFS claim runs (prevents parallel double-claim / double payout).
  fcfsClaimLockedAt      DateTime?

  @@unique([questId, userId])
}

/// Task individual dalam sebuah quest.
model QuestTask {
  id             String            @id @default(cuid())
  questId        String
  quest          Quest             @relation(fields: [questId], references: [id], onDelete: Cascade)
  type           String
  title          String
  description    String?
  points         Int               @default(10)
  target         String?
  order          Int               @default(0)
  /// Jawaban benar untuk tipe quiz (opsional)
  correctAnswer  String?
  /// Tampilkan badge "NEW" di halaman Quest user
  showNewBadge   Boolean           @default(false)
  /// Task tetap tampil; user bisa dapat poin lagi setiap 24 jam (daily check-in selalu aktif)
  repeatEvery24h Boolean           @default(false)
  createdAt      DateTime          @default(now())
  submissions    QuestSubmission[]
}

/// Submission satu task oleh satu user.
model QuestSubmission {
  id          String           @id @default(cuid())
  userId      String
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  questId     String
  quest       Quest            @relation(fields: [questId], references: [id], onDelete: Cascade)
  taskId      String
  task        QuestTask        @relation(fields: [taskId], references: [id], onDelete: Cascade)
  /// Bukti dari user: URL, handle, jawaban, dll.
  proof       String?
  status      SubmissionStatus @default(PENDING)
  /// Canton ledger TX ID dari CC reward = Proof of Execution on-chain
  ledgerTxId  String?
  submittedAt DateTime         @default(now())
  verifiedAt  DateTime?

  @@unique([userId, taskId])
}

enum QuestKind {
  CAMPAIGN
  EARN_HUB
}

/// Mode gate akses Earn per-campaign (di-set admin per-event).
/// CC_OR_POINTS = lock CC ATAU spend points (default, perilaku lama).
/// CC_ONLY = hanya lock CC. POINTS_ONLY = hanya spend points. NONE = tanpa gate (event gratis).
enum EntryGateMode {
  CC_OR_POINTS
  CC_ONLY
  POINTS_ONLY
  NONE
}

enum QuestStatus {
  ACTIVE
  COMING_SOON
  ENDED
}

enum SubmissionStatus {
  PENDING
  VERIFIED
  REJECTED
}

/// Account access state. ACTIVE = full access (default for all existing users).
/// Enforcement (phase 1): login & refresh reject non-ACTIVE; ban/suspend revoke all sessions.
enum UserStatus {
  ACTIVE
  SUSPENDED
  BANNED
}

/// Key-value store untuk konfigurasi aplikasi (earn entry cost, dll).
model AppSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

/// Tracks which quests each user has completed.
model QuestCompletion {
  id                      String   @id @default(cuid())
  userId                  String
  user                    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  questId                 String
  quest                   Quest    @relation(fields: [questId], references: [id], onDelete: Cascade)
  /// CC reward in micro-CC already credited from this completion.
  rewardMicroCc           BigInt   @default(0)
  /// Canton ledger TX ID dari CC reward = bukti on-chain
  ledgerTxId              String?
  /// DAML QuestParticipation contract id (if recorded on ledger)
  ledgerParticipationId   String?
  /// DAML QuestReward contract id (if recorded on ledger)
  ledgerRewardId          String?
  /// DAML QuestTaskSubmission contract ids (JSON string array)
  ledgerTaskSubmissionIds Json     @default("[]")
  completedAt             DateTime @default(now())

  @@unique([userId, questId])
}

/// Pending delivery — token/CC yang swap-nya sukses tapi gagal dikirim
/// on-chain ke user party (mis. transfer offer tak ter-accept, network error).
/// User bisa accept/reject via UI, admin bisa refund/retry.
/// Replaces the old "fallback off-chain credit" pattern (source of balance drift).
model PendingDelivery {
  id                      String   @id @default(cuid())
  userId                  String
  user                    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// Link ke SwapTransaction asal (opsional — bisa juga dari path non-swap).
  swapTransactionId       String?
  swapTransaction         SwapTransaction? @relation(fields: [swapTransactionId], references: [id])
  /// User Canton party (receiver untuk delivery).
  userPartyId             String
  /// Token yang harus di-deliver.
  tokenId                 String
  tokenAdmin              String
  /// Amount token (Decimal, 38,18).
  amount                  Decimal  @db.Decimal(38, 18)
  /// Amount CC dalam micro-CC (1 CC = 1e6) bila token = CC/Amulet.
  amountMicroCc           BigInt?
  /// PENDING_APPROVAL (offer belum accept) | COMPLETED (sukses) | REJECTED (user reject) | REFUNDED (CC balik ke trading).
  status                  String   @default("PENDING_APPROVAL")
  /// 'direct' | 'offer' | 'unknown' — jenis transfer Cantex.
  transferKind            String?
  /// TransferInstruction contract id bila offer-kind (perlu accept/reject).
  transferInstructionCid  String?
  errorMessage            String?
  deliveredAt             DateTime?
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  @@index([userId, status])
  @@index([status, createdAt])
}
