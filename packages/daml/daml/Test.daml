-- ============================================================
-- CanQuest DAML Test Suite — module Test
-- Package: canquest-v21 (lean)  |  SDK: 3.4.11
-- Jalankan: daml test
--
-- Cakupan: 3 template (WalletRegistration, QuestCampaign, QuestClaim).
-- Menguji seluruh guard on-chain:
--   - Kuota FCFS / Raffle (sybil resistance)
--   - State machine campaign (anti-reopen CLOSED/ENDED)
--   - Ordering fee-before-reward & idempotency AtomicFeeAndReward
--   - Guard RevealRewardCode (fee dulu, kode tak kosong)
-- ============================================================

module Test where

import Daml.Script
import Main

testAllTemplates : Script ()
testAllTemplates = script do

  admin <- allocateParty "CanQuestAdmin"
  alice <- allocateParty "Alice_User"
  bob   <- allocateParty "Bob_User"
  carol <- allocateParty "Carol_User"

  -- [A] WALLET REGISTRATION (create-only)

  _aliceWalletCid <- submit admin do
    createCmd WalletRegistration with
      admin
      userAddress  = alice
      username     = "Alice_CanQuest"
      partyId      = "Alice_CanQuest::122abc"
      inviteCode   = "ADMIN_CODE_001"
      registeredAt = "2026-06-05T00:00:00Z"

  _bobWalletCid <- submit admin do
    createCmd WalletRegistration with
      admin
      userAddress  = bob
      username     = "Bob_Canton"
      partyId      = "Bob_Canton::122def"
      inviteCode   = "ADMIN_CODE_002"
      registeredAt = "2026-06-05T00:00:00Z"

  -- [B] QUEST CAMPAIGN — CC FCFS (kuota maxWinners=2)

  ccFcfsCampaignCid <- submit admin do
    createCmd QuestCampaign with
      admin
      campaignId    = "CAMPAIGN_CC_FCFS_001"
      title         = "Canton Network CC Quest"
      questKind     = "CC_FCFS"
      rewardCc      = 10.0
      claimFeeCc    = 3.0
      maxWinners    = 2
      currentClaims = 0
      status        = "ACTIVE"
      createdAt     = "2026-06-05T00:00:00Z"

  (ccFcfsCampaignCid2, aliceClaimCid) <- submit admin do
    exerciseCmd ccFcfsCampaignCid ClaimFcfsSlot with
      user      = alice
      claimId   = "CLAIM_CC_FCFS_001"
      claimedAt = "2026-06-05T01:00:00Z"

  (ccFcfsCampaignCid3, _bobClaimCid) <- submit admin do
    exerciseCmd ccFcfsCampaignCid2 ClaimFcfsSlot with
      user      = bob
      claimId   = "CLAIM_CC_FCFS_002"
      claimedAt = "2026-06-05T01:01:00Z"

  -- Claim ke-3 setelah maxWinners=2 tercapai → GAGAL (sybil resistance)
  submitMustFail admin do
    exerciseCmd ccFcfsCampaignCid3 ClaimFcfsSlot with
      user      = carol
      claimId   = "CLAIM_CC_FCFS_003"
      claimedAt = "2026-06-05T01:02:00Z"

  -- ENDED lalu claim → GAGAL (guard status)
  ccFcfsCampaignCid4 <- submit admin do
    exerciseCmd ccFcfsCampaignCid3 UpdateCampaignStatus with
      newStatus = "ENDED"
      updatedAt = "2026-06-05T23:00:00Z"

  _closedCampaignCid <- submit admin do
    exerciseCmd ccFcfsCampaignCid4 CloseCampaign with
      closedAt = "2026-06-05T23:59:00Z"

  -- Claim pada ENDED → GAGAL
  submitMustFail admin do
    exerciseCmd ccFcfsCampaignCid4 ClaimFcfsSlot with
      user      = carol
      claimId   = "CLAIM_CC_FCFS_004"
      claimedAt = "2026-06-05T23:59:30Z"

  -- [C] QUEST CAMPAIGN — CODE FCFS (kuota maxWinners=1)

  codeFcfsCampaignCid <- submit admin do
    createCmd QuestCampaign with
      admin
      campaignId    = "CAMPAIGN_CODE_FCFS_001"
      title         = "Canton Invite Code Quest"
      questKind     = "CODE_FCFS"
      rewardCc      = 0.0
      claimFeeCc    = 2.0
      maxWinners    = 1
      currentClaims = 0
      status        = "ACTIVE"
      createdAt     = "2026-06-05T00:00:00Z"

  (_codeFcfsCampaignCid2, _aliceCodeClaimCid) <- submit admin do
    exerciseCmd codeFcfsCampaignCid ClaimFcfsSlot with
      user      = alice
      claimId   = "CLAIM_CODE_FCFS_001"
      claimedAt = "2026-06-05T02:00:00Z"

  -- Claim ke-2 setelah maxWinners=1 → GAGAL
  submitMustFail admin do
    exerciseCmd codeFcfsCampaignCid ClaimFcfsSlot with
      user      = bob
      claimId   = "CLAIM_CODE_FCFS_002"
      claimedAt = "2026-06-05T02:01:00Z"

  -- [D] QUEST CAMPAIGN — CC RAFFLE (maxWinners=0 = unlimited)

  ccRaffleCampaignCid <- submit admin do
    createCmd QuestCampaign with
      admin
      campaignId    = "CAMPAIGN_CC_RAFFLE_001"
      title         = "Canton CC Raffle Event"
      questKind     = "CC_RAFFLE"
      rewardCc      = 50.0
      claimFeeCc    = 3.0
      maxWinners    = 0
      currentClaims = 0
      status        = "ACTIVE"
      createdAt     = "2026-06-05T00:00:00Z"

  (ccRaffleCampaignCid2, aliceRaffleClaimCid) <- submit admin do
    exerciseCmd ccRaffleCampaignCid DrawRaffleWinner with
      user       = alice
      claimId    = "CLAIM_CC_RAFFLE_001"
      rewardCode = ""
      drawnAt    = "2026-06-05T20:00:00Z"

  (_ccRaffleCampaignCid3, _bobRaffleClaimCid) <- submit admin do
    exerciseCmd ccRaffleCampaignCid2 DrawRaffleWinner with
      user       = bob
      claimId    = "CLAIM_CC_RAFFLE_002"
      rewardCode = ""
      drawnAt    = "2026-06-05T20:01:00Z"

  -- [E] QUEST CAMPAIGN — CODE RAFFLE

  codeRaffleCampaignCid <- submit admin do
    createCmd QuestCampaign with
      admin
      campaignId    = "CAMPAIGN_CODE_RAFFLE_001"
      title         = "Canton Code Raffle Event"
      questKind     = "CODE_RAFFLE"
      rewardCc      = 0.0
      claimFeeCc    = 2.0
      maxWinners    = 0
      currentClaims = 0
      status        = "ACTIVE"
      createdAt     = "2026-06-05T00:00:00Z"

  (_codeRaffleCampaignCid2, carolCodeRaffleClaimCid) <- submit admin do
    exerciseCmd codeRaffleCampaignCid DrawRaffleWinner with
      user       = carol
      claimId    = "CLAIM_CODE_RAFFLE_001"
      rewardCode = "INVITE_CODE_XYZ789"
      drawnAt    = "2026-06-05T21:00:00Z"

  -- Draw pada campaign FCFS → GAGAL (questKind mismatch)
  submitMustFail admin do
    exerciseCmd ccFcfsCampaignCid DrawRaffleWinner with
      user       = carol
      claimId    = "CLAIM_INVALID_001"
      rewardCode = ""
      drawnAt    = "2026-06-05T21:01:00Z"

  -- [F] QUEST CAMPAIGN — CC_AND_CODE_RAFFLE

  ccAndCodeRaffleCid <- submit admin do
    createCmd QuestCampaign with
      admin
      campaignId    = "CAMPAIGN_CC_AND_CODE_001"
      title         = "Canton CC + Code Raffle"
      questKind     = "CC_AND_CODE_RAFFLE"
      rewardCc      = 20.0
      claimFeeCc    = 5.0
      maxWinners    = 0
      currentClaims = 0
      status        = "ACTIVE"
      createdAt     = "2026-06-05T00:00:00Z"

  (ccAndCodeRaffleCid2, aliceCcCodeClaimCid) <- submit admin do
    exerciseCmd ccAndCodeRaffleCid DrawRaffleWinner with
      user       = alice
      claimId    = "CLAIM_CC_CODE_001"
      rewardCode = "INVITE_CODE_ALICE_001"
      drawnAt    = "2026-06-05T22:00:00Z"

  (_ccAndCodeRaffleCid3, _bobCcCodeClaimCid) <- submit admin do
    exerciseCmd ccAndCodeRaffleCid2 DrawRaffleWinner with
      user       = bob
      claimId    = "CLAIM_CC_CODE_002"
      rewardCode = "INVITE_CODE_BOB_001"
      drawnAt    = "2026-06-05T22:01:00Z"

  -- [G] QUEST CAMPAIGN — WAITLIST

  waitlistCampaignCid <- submit admin do
    createCmd QuestCampaign with
      admin
      campaignId    = "CAMPAIGN_WAITLIST_001"
      title         = "Canton Waitlist Event"
      questKind     = "WAITLIST"
      rewardCc      = 0.0
      claimFeeCc    = 0.0
      maxWinners    = 0
      currentClaims = 0
      status        = "ACTIVE"
      createdAt     = "2026-06-05T00:00:00Z"

  (_waitlistCampaignCid2, _carolWaitlistClaimCid) <- submit admin do
    exerciseCmd waitlistCampaignCid DrawRaffleWinner with
      user       = carol
      claimId    = "CLAIM_WAITLIST_001"
      rewardCode = ""
      drawnAt    = "2026-06-05T23:00:00Z"

  -- ClaimFcfsSlot pada WAITLIST → GAGAL (questKind mismatch)
  submitMustFail admin do
    exerciseCmd waitlistCampaignCid ClaimFcfsSlot with
      user      = alice
      claimId   = "CLAIM_WAITLIST_INVALID"
      claimedAt = "2026-06-05T23:01:00Z"

  -- [H] QUEST CLAIM — AtomicFeeAndReward (positive + idempotency)

  -- Atomic settlement pertama harus BERHASIL (fee+reward dalam 1 tx DAML)
  atomicClaimFinalCid <- submit admin do
    exerciseCmd aliceClaimCid AtomicFeeAndReward with
      feeTxId     = "SPLICE_FEE_TX_ALICE_001"
      rewardTxId  = "SPLICE_REWARD_TX_ALICE_001"
      rewardSentAt = "2026-06-05T01:06:00Z"

  -- Atomic settlement kedua pada kontrak final → GAGAL (rewardSent sudah True)
  submitMustFail admin do
    exerciseCmd atomicClaimFinalCid AtomicFeeAndReward with
      feeTxId     = "SPLICE_FEE_TX_ALICE_002"
      rewardTxId  = "SPLICE_REWARD_TX_ALICE_002"
      rewardSentAt = "2026-06-05T01:07:00Z"

  -- Raffle claim juga bisa di-atomic-settle
  _aliceRaffleFinalCid <- submit admin do
    exerciseCmd aliceRaffleClaimCid AtomicFeeAndReward with
      feeTxId     = "SPLICE_FEE_TX_ALICE_RAFFLE_001"
      rewardTxId  = "SPLICE_REWARD_TX_ALICE_RAFFLE_001"
      rewardSentAt = "2026-06-05T20:06:00Z"

  -- [I] QUEST CLAIM — RevealRewardCode

  -- CC+Code raffle: fee dulu, baru reveal kode
  aliceCcCodeClaimCid2 <- submit admin do
    exerciseCmd aliceCcCodeClaimCid AtomicFeeAndReward with
      feeTxId     = "SPLICE_FEE_TX_ALICE_CC_CODE_001"
      rewardTxId  = "SPLICE_REWARD_TX_ALICE_CC_CODE_001"
      rewardSentAt = "2026-06-05T22:06:00Z"

  _aliceCcCodeClaimCid3 <- submit admin do
    exerciseCmd aliceCcCodeClaimCid2 RevealRewardCode with
      code       = "INVITE_CODE_ALICE_REVEALED"
      revealedAt = "2026-06-05T22:07:00Z"

  -- Reveal kode kosong → GAGAL
  submitMustFail admin do
    exerciseCmd aliceCcCodeClaimCid2 RevealRewardCode with
      code       = ""
      revealedAt = "2026-06-05T22:08:00Z"

  -- Reveal pada claim yang FEE belum dibayar & claimFeeCc>0 → GAGAL
  testRevealCampaignCid <- submit admin do
    createCmd QuestCampaign with
      admin
      campaignId    = "CAMPAIGN_TEST_REVEAL"
      title         = "Test Reveal"
      questKind     = "CODE_RAFFLE"
      rewardCc      = 0.0
      claimFeeCc    = 2.0
      maxWinners    = 0
      currentClaims = 0
      status        = "ACTIVE"
      createdAt     = "2026-06-05T00:00:00Z"

  (_, testRevealClaimCid) <- submit admin do
    exerciseCmd testRevealCampaignCid DrawRaffleWinner with
      user       = carol
      claimId    = "CLAIM_TEST_REVEAL_001"
      rewardCode = ""
      drawnAt    = "2026-06-05T22:10:00Z"

  submitMustFail admin do
    exerciseCmd testRevealClaimCid RevealRewardCode with
      code       = "SHOULD_FAIL"
      revealedAt = "2026-06-05T22:11:00Z"

  -- Edge: claim dengan claimFeeCc=0 → RevealRewardCode boleh tanpa fee
  testEmptyCodeCampaignCid <- submit admin do
    createCmd QuestCampaign with
      admin
      campaignId    = "CAMPAIGN_TEST_EMPTY_CODE"
      title         = "Test Empty Code"
      questKind     = "CODE_RAFFLE"
      rewardCc      = 0.0
      claimFeeCc    = 0.0
      maxWinners    = 0
      currentClaims = 0
      status        = "ACTIVE"
      createdAt     = "2026-06-05T00:00:00Z"

  (_, testEmptyCodeClaimCid) <- submit admin do
    exerciseCmd testEmptyCodeCampaignCid DrawRaffleWinner with
      user       = alice
      claimId    = "CLAIM_TEST_EMPTY_CODE_001"
      rewardCode = ""
      drawnAt    = "2026-06-05T23:30:00Z"

  _testEmptyCodeRevealedCid <- submit admin do
    exerciseCmd testEmptyCodeClaimCid RevealRewardCode with
      code       = "FREE_CODE_OK"
      revealedAt = "2026-06-05T23:31:00Z"

  -- [J] RAFFLE GUARD (H-1, H-2, H-3)

  -- Draw pada campaign CLOSED → GAGAL (H-1)
  closedRaffleCid <- submit admin do
    createCmd QuestCampaign with
      admin
      campaignId    = "CAMPAIGN_CLOSED_RAFFLE"
      title         = "Closed Raffle Test"
      questKind     = "CC_RAFFLE"
      rewardCc      = 10.0
      claimFeeCc    = 2.0
      maxWinners    = 0
      currentClaims = 0
      status        = "ACTIVE"
      createdAt     = "2026-06-05T00:00:00Z"

  closedRaffleEndedCid <- submit admin do
    exerciseCmd closedRaffleCid UpdateCampaignStatus with
      newStatus = "ENDED"
      updatedAt = "2026-06-05T23:00:00Z"

  closedRaffleClosedCid <- submit admin do
    exerciseCmd closedRaffleEndedCid CloseCampaign with
      closedAt = "2026-06-05T23:30:00Z"

  submitMustFail admin do
    exerciseCmd closedRaffleClosedCid DrawRaffleWinner with
      user       = alice
      claimId    = "CLAIM_CLOSED_RAFFLE_FAIL"
      rewardCode = ""
      drawnAt    = "2026-06-05T23:35:00Z"

  -- Reopen CLOSED → ACTIVE → GAGAL (H-3: state machine)
  submitMustFail admin do
    exerciseCmd closedRaffleClosedCid UpdateCampaignStatus with
      newStatus = "ACTIVE"
      updatedAt = "2026-06-05T23:40:00Z"

  -- Raffle quota: draw melebihi maxWinners → GAGAL (H-2)
  quotaRaffleCid <- submit admin do
    createCmd QuestCampaign with
      admin
      campaignId    = "CAMPAIGN_RAFFLE_QUOTA"
      title         = "Raffle Quota Test"
      questKind     = "CC_RAFFLE"
      rewardCc      = 5.0
      claimFeeCc    = 1.0
      maxWinners    = 1
      currentClaims = 0
      status        = "ACTIVE"
      createdAt     = "2026-06-05T00:00:00Z"

  (quotaRaffleCid2, _) <- submit admin do
    exerciseCmd quotaRaffleCid DrawRaffleWinner with
      user       = alice
      claimId    = "CLAIM_RAFFLE_QUOTA_001"
      rewardCode = ""
      drawnAt    = "2026-06-05T20:00:00Z"

  submitMustFail admin do
    exerciseCmd quotaRaffleCid2 DrawRaffleWinner with
      user       = bob
      claimId    = "CLAIM_RAFFLE_QUOTA_002"
      rewardCode = ""
      drawnAt    = "2026-06-05T20:01:00Z"

  -- [K] EDGE CASES

  -- CloseCampaign dengan closedAt kosong → GAGAL
  submitMustFail admin do
    exerciseCmd ccFcfsCampaignCid CloseCampaign with
      closedAt = ""

  -- UpdateCampaignStatus dengan newStatus kosong → GAGAL
  submitMustFail admin do
    exerciseCmd ccFcfsCampaignCid UpdateCampaignStatus with
      newStatus = ""
      updatedAt = "2026-06-05T23:00:00Z"

  -- Transisi tidak sah: ACTIVE → DRAFT → GAGAL
  submitMustFail admin do
    exerciseCmd ccRaffleCampaignCid UpdateCampaignStatus with
      newStatus = "DRAFT"
      updatedAt = "2026-06-05T23:00:00Z"

  -- AtomicFeeAndReward pada claim tanpa fee & tanpa reward → GAGAL
  zeroValueCampaignCid <- submit admin do
    createCmd QuestCampaign with
      admin
      campaignId    = "CAMPAIGN_ZERO_VALUE"
      title         = "Zero Value Test"
      questKind     = "CODE_FCFS"
      rewardCc      = 0.0
      claimFeeCc    = 0.0
      maxWinners    = 0
      currentClaims = 0
      status        = "ACTIVE"
      createdAt     = "2026-06-05T00:00:00Z"

  (_, zeroValueClaimCid) <- submit admin do
    exerciseCmd zeroValueCampaignCid ClaimFcfsSlot with
      user      = bob
      claimId   = "CLAIM_ZERO_VALUE_001"
      claimedAt = "2026-06-05T03:00:00Z"

  submitMustFail admin do
    exerciseCmd zeroValueClaimCid AtomicFeeAndReward with
      feeTxId     = "SPLICE_FEE_ZERO"
      rewardTxId  = "SPLICE_REWARD_ZERO"
      rewardSentAt = "2026-06-05T03:05:00Z"

  -- AtomicFeeAndReward dengan feeTxId kosong → GAGAL (fresh claim, belum archived)
  emptyFeeCampaignCid <- submit admin do
    createCmd QuestCampaign with
      admin
      campaignId    = "CAMPAIGN_EMPTY_FEE_TX"
      title         = "Empty Fee Tx Test"
      questKind     = "CC_FCFS"
      rewardCc      = 5.0
      claimFeeCc    = 1.0
      maxWinners    = 0
      currentClaims = 0
      status        = "ACTIVE"
      createdAt     = "2026-06-05T00:00:00Z"

  (_, emptyFeeClaimCid) <- submit admin do
    exerciseCmd emptyFeeCampaignCid ClaimFcfsSlot with
      user      = bob
      claimId   = "CLAIM_EMPTY_FEE_TX_001"
      claimedAt = "2026-06-05T04:00:00Z"

  submitMustFail admin do
    exerciseCmd emptyFeeClaimCid AtomicFeeAndReward with
      feeTxId     = ""
      rewardTxId  = "SPLICE_REWARD_TX"
      rewardSentAt = "2026-06-05T04:05:00Z"

  pure ()
